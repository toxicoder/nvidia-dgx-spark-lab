# Example Secret for lab-dashboard auth (create manually; do not commit real values).
#
#   kubectl create secret generic lab-dashboard-auth -n dev \
#     --from-literal=secret='$(openssl rand -base64 32)' \
#     --from-literal=admin-email='admin@lab.local' \
#     --from-literal=admin-password='change-me-on-first-login'
#
apiVersion: v1
kind: Secret
metadata:
  name: lab-dashboard-auth
  namespace: dev
type: Opaque
stringData:
  secret: "replace-with-openssl-rand-base64-32"
  admin-email: "admin@lab.local"
  admin-password: "replace-me"