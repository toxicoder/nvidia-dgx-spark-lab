{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dashboard: Next.js",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/dashboard",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "started server on .+, url: (https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Vitest: Current File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vitest", "run", "${relativeFile}"],
      "cwd": "${workspaceFolder}/dashboard",
      "console": "integratedTerminal",
      "env": {
        "USE_MOCKS": "1"
      }
    }
  ],
  "compounds": [
    {
      "name": "Dashboard: Next.js + Chrome",
      "configurations": ["Dashboard: Next.js"],
      "presentation": {
        "hidden": false,
        "group": "dashboard",
        "order": 1
      }
    }
  ]
}