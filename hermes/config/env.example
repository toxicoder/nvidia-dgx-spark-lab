# Copy to hermes/data/.env (auto-seeded on first hermes-stack start).
# Generate secrets locally: openssl rand -hex 32
#
# PRIVACY: leave values empty or use obvious placeholders only.
# Never commit hermes/data/.env or real API keys / tokens.

API_SERVER_KEY=
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=lab
# Placeholder only — replace on first deploy; never use a real password in git.
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=
HERMES_DASHBOARD_BASIC_AUTH_SECRET=
# Lab inference is local/port-forward; "none" is intentional (not a cloud key).
OPENAI_API_KEY=none
