# Copy to .env for local development (never commit .env).
# All values below are placeholders — replace before running.

BETTER_AUTH_SECRET=dev-only-change-me
LAB_DASHBOARD_ADMIN_PASSWORD=change-me
# Optional in dev (auto dev key if unset). Production: openssl rand -base64 32
# LAB_SECRETS_MASTER_KEY=
DATABASE_URL=file:./data/lab-dashboard.db
# Domain config (defaults match config/lab-domains.yaml)
# LAB_LOCAL_DOMAIN=lab.local
# LAB_PUBLIC_DOMAIN=
# LAB_EMAIL_DOMAIN=lab.local