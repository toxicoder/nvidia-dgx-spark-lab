"""Package purpose: MkDocs site serve/build binaries and docs generator/render test targets."""

"""Bazel integration for the Material for MkDocs documentation site.

This provides first-class Bazel targets while keeping the shell scripts
(docs/setup-docs.sh and docs/manage-docs.sh) as the primary, simple
interface that works everywhere (including without Bazel installed).

Usage:
  bazel run //docs:serve
  bazel run //docs:docs   # builds the site
  bazel run //docs:status
  bazel run //docs:visual-update   # approve visual changes to site (see test_mkdocs_render)

See .bazelignore for generated output exclusions (site/, .venv-docs/).
"""

load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")

sh_binary(
    name = "serve",
    srcs = ["manage-docs.sh"],
    args = ["serve"],
    data = [
        "BUILDING_WITH_BAZEL.md",
        "CONTRIBUTING.md",
        "architecture.md",
        "assets",
        "models-catalog.md",
        "nemotron-agentic-stack.md",
        "monitoring-observability.md",
        "qwen36-dual-stack.md",
        "resource-guard.md",
        "troubleshooting.md",
        "dev-environment.md",
        "dev-workspaces.md",
        "dgx-spark-notes.md",
        "getting-started.md",
        "gitea-ci-setup.md",
        "generate_shell_docs.py",
        "glossary.md",
        "hermes-agent.md",
        "hooks.py",
        "includes",
        "index.md",
        "mcp-agent-toolkit.md",
        "open-webui.md",
        "project-conventions.md",
        "reboot-safety.md",
        "requirements.txt",
        "setup-docs.sh",
        "sso.md",
        "visual-generative-ai.md",
        "//:mkdocs.yml",
        # Script sources that feed the code generators (so Bazel correctly
        # invalidates docs targets when structured comments or sources change).
        "//scripts:doc_sources",
        # Generated content (populated at execution time by generate_code_docs)
        "generated",
    ],
    visibility = ["//visibility:public"],
)

sh_binary(
    name = "docs",
    srcs = ["manage-docs.sh"],
    args = ["build"],
    data = [
        "BUILDING_WITH_BAZEL.md",
        "CONTRIBUTING.md",
        "architecture.md",
        "assets",
        "dev-environment.md",
        "dev-workspaces.md",
        "dgx-spark-notes.md",
        "generate_shell_docs.py",
        "generated",
        "getting-started.md",
        "gitea-ci-setup.md",
        "glossary.md",
        "hermes-agent.md",
        "hooks.py",
        "includes",
        "index.md",
        "mcp-agent-toolkit.md",
        "models-catalog.md",
        "monitoring-observability.md",
        "nemotron-agentic-stack.md",
        "open-webui.md",
        "project-conventions.md",
        "qwen36-dual-stack.md",
        "reboot-safety.md",
        "requirements.txt",
        "resource-guard.md",
        "setup-docs.sh",
        "sso.md",
        "troubleshooting.md",
        "visual-generative-ai.md",
        "//:mkdocs.yml",
        "//scripts:doc_sources",
    ],
    visibility = ["//visibility:public"],
)

sh_binary(
    name = "status",
    srcs = ["manage-docs.sh"],
    args = ["status"],
    visibility = ["//visibility:public"],
)

sh_binary(
    name = "clean",
    srcs = ["manage-docs.sh"],
    args = ["clean"],
    visibility = ["//visibility:public"],
)

