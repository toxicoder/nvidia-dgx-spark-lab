# Render test data (shared). Includes goldens so the test (and update) can
# read committed screenshots for visual diff enforcement.
# Generated nav pages: shell reference + dashboard-api README tree (strict mkdocs).
_RENDER_GENERATED = glob(
    [
        "generated/shell/**",
        "generated/dashboard-api/**",
    ],
    allow_empty = True,
)

_RENDER_TEST_DATA = [
    "BUILDING_WITH_BAZEL.md",
    "CONTRIBUTING.md",
    "architecture.md",
    "assets",
    "dev-environment.md",
    "dev-workspaces.md",
    "dgx-spark-notes.md",
    "generate_shell_docs.py",
    "getting-started.md",
    "gitea-ci-setup.md",
    "glossary.md",
    "hermes-agent.md",
    "hooks.py",
    "includes",
    "index.md",
    "manage-docs.sh",
    "mcp-agent-toolkit.md",
    "models-catalog.md",
    "monitoring-observability.md",
    "nemotron-agentic-stack.md",
    "open-webui.md",
    "project-conventions.md",
    "qwen36-dual-stack.md",
    "reboot-safety.md",
    "requirements.txt",
    "resource-guard.md",
    "setup-docs.sh",
    "sso.md",
    "test_mkdocs_render.py",
    "test_mkdocs_render.sh",
    "tests",
    "tests/visual",
    "tests/visual/goldens",
    "troubleshooting.md",
    "visual-generative-ai.md",
    "//:mkdocs.yml",
    "//scripts:doc_sources",
] + _RENDER_GENERATED

# Render test: actually runs mkdocs build (the server-side render of the
# full site) and then inspects the produced HTML + source for elements
# and patterns that would only fail when the pages are opened in a browser
# (Mermaid JS parse errors, missing interactive panel divs, JS asset wiring,
# etc.).
#
# NOW ALSO: real browser screenshots (via Playwright + local static server)
# of key rendered pages are compared to goldens. This makes site rendering
# + visual regression first-class in the test suite. Tests fail on diffs.
# Use the :visual-update binary + UPDATE_SNAPSHOTS=1 to approve changes
# (followed by PR review of the golden diffs).
sh_test(
    name = "test_mkdocs_build",
    size = "medium",
    timeout = "moderate",
    srcs = ["test_mkdocs_build.sh"],
    data = _RENDER_TEST_DATA,
    visibility = ["//visibility:public"],
)

sh_test(
    name = "test_mkdocs_visual",
    size = "large",
    timeout = "long",
    srcs = ["test_mkdocs_visual.sh"],
    data = _RENDER_TEST_DATA,
    visibility = ["//visibility:public"],
)

sh_test(
    name = "test_mkdocs_render",
    size = "large",
    timeout = "long",
    srcs = ["test_mkdocs_render.sh"],
    data = _RENDER_TEST_DATA,
    visibility = ["//visibility:public"],
)

# Update runner for visual goldens (real browser render of the MkDocs site).
# Usage (from repo root):
#   UPDATE_SNAPSHOTS=1 bazel run //docs:visual-update
# This builds the site in temp, serves it, screenshots in real chromium,
# and overwrites goldens under docs/tests/visual/goldens/ using the
# real workspace path (so the new baselines are saved in your checkout).
# Always review the resulting image diffs before committing + PR.
sh_binary(
    name = "visual-update",
    srcs = ["test_mkdocs_render.sh"],
    data = _RENDER_TEST_DATA,
    visibility = ["//visibility:public"],
)
