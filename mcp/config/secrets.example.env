# Copy to mcp/config/secrets.env (never commit secrets.env).
# Used by: kubectl create secret generic mcp-secrets --from-env-file=...

# SearXNG instance secret (generate: openssl rand -hex 32)
SEARXNG_SECRET=change-me

# Context7 — optional; disable via CONTEXT7_ENABLED=false in context7-proxy deployment
CONTEXT7_API_KEY=

# Gitea/Forgejo PAT (read:repository, write:issue minimum)
GITEA_URL=https://gitea.example.com
GITEA_TOKEN=

# GitHub PAT for local workstation github-mcp-server (not stored in cluster by default)
GITHUB_PAT=

# Firecrawl self-hosted API key (any string when USE_DB_AUTHENTICATION=false)
FIRECRAWL_API_KEY=local-dev-key

# Mem0 admin bootstrap (see mem0 server docs)
MEM0_ADMIN_API_KEY=