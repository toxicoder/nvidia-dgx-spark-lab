# ## Dev / CI tool version pins (single source of truth)
#
# Sourced by:
#   - .devcontainer/Dockerfile (image build)
#   - .devcontainer/doctor.sh
#   - .github/scripts/install-lint-tools.sh
#   - .github/actions/setup-bazel (cache keys should match these pins)
#
# Keep amd64 + arm64 release artifacts available for every binary pin
# (Apple Silicon, DGX Spark Grace, Linux/Windows Docker Desktop hosts).
#
# Format: KEY=value (no spaces around =). BASH-sourceable.

# Bazelisk downloads Bazel from .bazelversion (currently 8.4.1).
BAZELISK_VERSION=v1.25.0
BUILDIFIER_VERSION=v8.2.1
SHFMT_VERSION=v3.10.0
# shfmt release asset embeds the version without a leading "v".
SHFMT_ASSET_VERSION=3.10.0
KUBECONFORM_VERSION=v0.8.0
HELM_VERSION=v3.15.0
# Pin kubectl to the same minor as //lints:k8s schema (1.30.0).
KUBECTL_VERSION=v1.30.14
PRETTIER_VERSION=3.9.4
NODE_MAJOR=22
PYTHON_VERSION=3.11
# Passed to kubeconform -kubernetes-version
KUBERNETES_SCHEMA_VERSION=1.30.0
