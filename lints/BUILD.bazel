"""Package purpose: Aggregate lint test suite (shellcheck, yaml, k8s kubeconform, buildifier, mypy).

Bazel entrypoints for linters used in the project. Tagged 'manual' because they depend on
external tools (shellcheck, yamllint, kubeconform, mypy) being present in PATH.
"""

load("@rules_shell//shell:sh_test.bzl", "sh_test")

package(default_visibility = ["//visibility:private"])

# Shell lint (shellcheck on all .sh)
sh_test(
    name = "shell",
    srcs = ["run_shellcheck.sh"],
    data = [
        "//:fix.sh",
        "//ansible:run_ansible_lint.sh",
        "//ansible:run_playbook.sh",
        "//ansible:run_syntax_check.sh",
        "//dashboard:run_npm.sh",
        "//scripts:doc_sources",
        "//scripts:lib/check_tool.sh",
        "//scripts:manage.sh",
        "//scripts:utilities",
        "//tests:bats_runner.sh",
    ],
    tags = [
        "lint",
        "local",
        "manual",
        "shellcheck",
    ],
)

# YAML format check (prettier --check; auto-fix via //:fix / scripts/yaml_format.sh --write)
sh_test(
    name = "yaml_format",
    srcs = ["run_prettier_yaml_check.sh"],
    data = [
        "//:.prettierignore",
        "//:prettier.config.mjs",
        "//scripts:lib/check_tool.sh",
        "//scripts:lib/paths.sh",
        "//scripts:yaml_format.sh",
    ],
    tags = [
        "lint",
        "local",
        "manual",
        "prettier",
        "yaml",
    ],
)

