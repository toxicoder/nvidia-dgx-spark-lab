# Bazel BUILD/.bzl formatting check (buildifier -mode=check).
# Tagged local: runs against BUILD_WORKSPACE_DIRECTORY (full tree), not sandbox data.
sh_test(
    name = "buildifier",
    srcs = ["buildifier_check.sh"],
    data = [
        "//scripts:doc_sources",
        "//scripts:lib/check_tool.sh",
    ],
    tags = [
        "buildifier",
        "lint",
        "local",
        "manual",
        "no-sandbox",
    ],
)

# Python strict typing (mypy per mypy.ini).
sh_test(
    name = "mypy",
    srcs = ["run_mypy.sh"],
    data = [
        "//:mypy.ini",
        "//scripts:lib/check_tool.sh",
    ],
    tags = [
        "lint",
        "local",
        "manual",
        "mypy",
    ],
)

test_suite(
    name = "all",
    tags = ["lint"],
    tests = [
        ":buildifier",
        ":k8s",
        ":mypy",
        ":shell",
        ":yaml",
        ":yaml_format",
    ],
)
