{
  "helm": {
    "repo": "https://open-webui.github.io/helm-charts",
    "chart": "open-webui",
    "release": "open-webui",
    "namespace": "dev",
    "chart_version": "7.4.0"
  },
  "ports": {
    "nodeport": 32085,
    "container": 8080,
    "service": 80
  },
  "sso": {
    "host": "chat"
  },
  "backends": {
    "hermes_gateway": {
      "service": "hermes-gateway",
      "namespace": "dev",
      "port": 8642,
      "path": "/v1",
      "requires_hermes_stack": "hermes-lab"
    }
  },
  "stacks": {
    "open-webui-lab": {
      "label": "Open WebUI (Hermes agent chat)",
      "heavy": false,
      "tier": "optional_dev",
      "description": "Browser chat UI backed by Hermes gateway (MCP agent orchestration)",
      "requires_hermes_stack": "hermes-lab"
    }
  }
}
