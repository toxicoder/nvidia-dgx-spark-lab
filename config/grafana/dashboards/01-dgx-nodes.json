{
  "uid": "spark-nodes",
  "title": "DGX Spark \u2014 Node Metrics",
  "tags": [
    "spark-lab",
    "nodes"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": false,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "links": [
    {
      "title": "Overview",
      "url": "/d/spark-overview",
      "type": "link"
    },
    {
      "title": "GPU Cluster",
      "url": "/d/spark-gpu",
      "type": "link"
    },
    {
      "title": "Kubernetes",
      "url": "/d/spark-k8s",
      "type": "link"
    },
    {
      "title": "Inference",
      "url": "/d/spark-inference",
      "type": "link"
    },
    {
      "title": "Platform",
      "url": "/d/spark-platform",
      "type": "link"
    },
    {
      "title": "Dev & Agent",
      "url": "/d/spark-dev-agent",
      "type": "link"
    },
    {
      "title": "Storage & Network",
      "url": "/d/spark-storage-net",
      "type": "link"
    },
    {
      "title": "Lab Dashboard",
      "url": "https://dashboard.lab.local:32443/#observability",
      "type": "link",
      "targetBlank": true
    }
  ],
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(node_uname_info, nodename)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Per-Node Resources",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Util %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",nodename=~\"$node\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory Used %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{nodename=~\"$node\"} / node_memory_MemTotal_bytes{nodename=~\"$node\"}) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Disk Util %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",nodename=~\"$node\"} / node_filesystem_size_bytes{mountpoint=\"/\",nodename=~\"$node\"}) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Network RX",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*\",nodename=~\"$node\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Load Average (1m)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "node_load1{nodename=~\"$node\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    }
  ]
}